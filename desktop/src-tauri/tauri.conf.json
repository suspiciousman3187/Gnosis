{
    "$schema":  "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName":  "Gnosis",
    "version":  "0.0.2",
    "identifier":  "com.styx.app",
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:5183",
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Gnosis",
                                    "width":  1280,
                                    "height":  860,
                                    "minWidth":  900,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "decorations":  false,
                                    "visible":  false,
                                    "backgroundColor":  "#121a28"
                                }
                            ],
                "security":  {
                                 "csp":  null,
                                 "assetProtocol":  {
                                                       "enable":  true,
                                                       "scope":  [
                                                                     "**"
                                                                 ]
                                                   }
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "createUpdaterArtifacts":  true,
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "android":  {
                                   "debugApplicationIdSuffix":  ".debug"
                               }
               },
    "plugins":  {
                    "updater":  {
                                    "endpoints":  [
                                                      "https://gnosis-xi.com/updates/desktop.json"
                                                  ],
                                    "pubkey":  "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExN0FDRjVBMDkyOTg0ODQKUldTRWhDa0pXczk2b1ZMUzc4ZktrUjJTUHU4WUdYZFJRQU9hb0h5a3UxclIyVktOVUZ3ODVpUnMK",
                                    "dialog":  false
                                }
                }
}